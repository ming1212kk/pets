page {
  min-height: 100%;
  background: linear-gradient(180deg, #eef7ef 0%, #f8f3eb 100%);
  color: #1f2937;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.shell {
  padding: 24rpx;
}

.panel {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 50rpx rgba(20, 52, 43, 0.08);
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #14342b;
  margin-bottom: 20rpx;
}

.subtle {
  color: #6b7280;
  font-size: 24rpx;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #4b5563;
  margin-bottom: 10rpx;
}

.input,
.textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  border-radius: 20rpx;
  padding: 20rpx;
  background: #f9fafb;
  border: 2rpx solid #dde5de;
}

.textarea {
  min-height: 180rpx;
}

.btn {
  width: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #14342b 0%, #2d6a4f 100%);
  color: #ffffff;
  font-size: 28rpx;
  margin-top: 12rpx;
}

.btn-secondary {
  background: #edf2ef;
  color: #14342b;
}

.btn-danger {
  background: #b42318;
  color: #ffffff;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row > view,
.row > button {
  flex: 1;
}

.chip {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf7f1;
  color: #2d6a4f;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.card {
  border-radius: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #14342b;
  margin-bottom: 12rpx;
}

.card-copy {
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.meta {
  font-size: 22rpx;
  color: #6b7280;
}

.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.actions button {
  flex: 1;
  margin: 0;
}

.inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.inline-actions button {
  margin: 0;
  min-width: 180rpx;
  padding: 0 24rpx;
  line-height: 72rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
}

.segmented {
  display: flex;
  gap: 12rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid #d7e3da;
  background: #f8fbf8;
  color: #4b5563;
  font-size: 24rpx;
}

.segment-item.active {
  border-color: #2d6a4f;
  background: #e8f4eb;
  color: #14342b;
  font-weight: 700;
}

.checkbox-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.checkbox-card {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f8faf9;
  border: 2rpx solid #dde5de;
}

.checkbox-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.nested-list {
  margin-top: 16rpx;
  padding-left: 24rpx;
  border-left: 4rpx solid #e3ece4;
}

.reply-card {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f7faf8;
}

.reply-context {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #eef7ef;
}

.section-hint {
  margin-top: 8rpx;
  margin-bottom: 14rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-pill {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #f6faf7;
  border: 2rpx solid #e1eae2;
}

.ghost-button {
  background: transparent;
  color: #14342b;
  border: 2rpx solid #d5e3d7;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.avatar-fallback {
  width: 108rpx;
  height: 108rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #14342b 0%, #2d6a4f 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #14342b;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.summary-item {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #f7faf8;
  border: 2rpx solid #e2ebe3;
}
